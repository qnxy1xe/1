		}),
		utility:Create("TextBox", {
			Name = "Value",
		BackgroundColor3 = Color3.fromRGB(55, 55, 75),
			BackgroundTransparency = 0.4,
			BorderSizePixel = 0,
			Position = UDim2.new(1, -50, 0, 4),
			Size = UDim2.new(0, 40, 0, 16),
			Font = Enum.Font.Gotham,
			Text = tostring(default or min),
			TextColor3 = Color3.fromRGB(200, 200, 210),
			TextSize = 10,
			TextXAlignment = Enum.TextXAlignment.Center
		}, {
			utility:Create("UICorner", {
				CornerRadius = UDim.new(0, 4)
			})
		}),
		utility:Create("Frame", {
			Name = "SliderBar",
		BackgroundColor3 = Color3.fromRGB(55, 55, 75),
			BackgroundTransparency = 0.4,
			BorderSizePixel = 0,
			Position = UDim2.new(0, 12, 0, 26),
			Size = UDim2.new(1, -24, 0, 8)
		}, {
			utility:Create("UICorner", {
				CornerRadius = UDim.new(0, 4)
			}),
			utility:Create("Frame", {
				Name = "Fill",
				BackgroundColor3 = Color3.fromRGB(120, 150, 200),
				BorderSizePixel = 0,
				Size = UDim2.new(0.5, 0, 1, 0)
			}, {
				utility:Create("UICorner", {
					CornerRadius = UDim.new(0, 4)
				})
			})
		})
	})
	
	table.insert(self.modules, slider)
	
	local sliderBar = slider.SliderBar
	local fill = sliderBar.Fill
	local value = slider.Value
	
	local sliderCallback = function(val)
		if callback then
			callback(val, function(...)
				self:updateSlider(slider, ...)
			end)
		end
	end
	
	slider.MouseButton1Down:Connect(function()
		local dragging = true
		while dragging do
			local relativeX = mouse.X - sliderBar.AbsolutePosition.X
			local percent = math.clamp(relativeX / sliderBar.AbsoluteSize.X, 0, 1)
			local val = math.floor(min + (max - min) * percent)
			
			value.Text = tostring(val)
			fill.Size = UDim2.new(percent, 0, 1, 0)
			
			sliderCallback(val)
			run.RenderStepped:Wait()
		end
	end)
	
	input.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	return slider
end

