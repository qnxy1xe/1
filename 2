    -- [NEW] Added Slider with Luna Smooth Animation
	function library:AddSlider(parent, text, min, max, callback)
		local slider = utility:Create("Frame", {
			Parent = parent,
			Size = UDim2.new(1, -20, 0, 40),
			BackgroundTransparency = 1
		}, {
			utility:Create("TextLabel", {
				Text = text,
				Size = UDim2.new(1, 0, 0, 20),
				TextColor3 = themes.TextColor,
				BackgroundTransparency = 1,
				Font = Enum.Font.Gotham
			}),
			utility:Create("Frame", {
				Name = "Rail",
				Position = UDim2.new(0, 0, 0, 25),
				Size = UDim2.new(1, 0, 0, 4),
				BackgroundColor3 = themes.DarkContrast
			}, {
				utility:Create("Frame", {
					Name = "Fill",
					Size = UDim2.new(0.5, 0, 1, 0),
					BackgroundColor3 = themes.TextColor
				})
			})
		})

		local fill = slider.Rail.Fill
		local dragging = false

		local function update()
			local percent = math.clamp((mouse.X - slider.Rail.AbsolutePosition.X) / slider.Rail.AbsoluteSize.X, 0, 1)
			-- Smooth Fill Animation
			utility:Tween(fill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
			callback(math.floor(min + (max - min) * percent))
		end

		slider.Rail.InputBegan:Connect(function(inputObj)
			if inputObj.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				update()
			end
		end)

		input.InputEnded:Connect(function(inputObj)
			if inputObj.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)

		run.RenderStepped:Connect(function()
			if dragging then update() end
		end)
	end
end

return library
