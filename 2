			Name = "Title",
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 6),
			Size = UDim2.new(0.5, 0, 0, 16),
			Font = Enum.Font.Gotham,
			Text = title,
			TextColor3 = Color3.fromRGB(200, 200, 210),
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Left
		}),
		utility:Create("TextBox", {
			Name = "TextBox",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Position = UDim2.new(1, -30, 0, 6),
			Size = UDim2.new(0, 20, 0, 16),
			Font = Enum.Font.GothamSemibold,
			Text = tostring(default or min),
			TextColor3 = Color3.fromRGB(200, 200, 210),
			TextSize = 11,
			TextXAlignment = Enum.TextXAlignment.Right
		}),
		utility:Create("Frame", {
			Name = "Slider",
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 28),
			Size = UDim2.new(1, -20, 0, 16),
			Text = ""
		}, {
			utility:Create("Frame", {
				Name = "Bar",
				AnchorPoint = Vector2.new(0, 0.5),
				BackgroundColor3 = Color3.fromRGB(60, 60, 80),
				BackgroundTransparency = 0.3,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 0, 0.5, 0),
				Size = UDim2.new(1, 0, 0, 4)
			}, {
				utility:Create("Frame", {
					Name = "Fill",
					BackgroundColor3 = Color3.fromRGB(120, 150, 200),
					BorderSizePixel = 0,
					Size = UDim2.new(0.5, 0, 1, 0)
				})
			})
		})
	})
	
	table.insert(self.modules, slider)
	
	local bar = slider.Slider.Bar
	local fill = bar.Fill
	local value = slider.TextBox
	
	local sliderCallback = function(val)
		if callback then
			callback(val, function(...)
				self:updateSlider(slider, ...)
			end)
		end
	end
	
	slider.MouseButton1Down:Connect(function()
		local dragging = true
		while dragging do
			local relativeX = mouse.X - bar.AbsolutePosition.X
			local percent = math.clamp(relativeX / bar.AbsoluteSize.X, 0, 1)
			local val = math.floor(min + (max - min) * percent)
			
			value.Text = tostring(val)
			fill.Size = UDim2.new(percent, 0, 1, 0)
			
			sliderCallback(val)
			run.RenderStepped:Wait()
		end
	end)
	
	input.InputEnded:Connect(function(inputObj)
		if inputObj.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	return slider
end

