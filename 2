function section:updateDropdown(dropdown, title, list, callback)
	if not dropdown then return end
	
	list = list or {}
	local listFrame = dropdown.List
	local scrollFrame = listFrame.Scroll
	
	for _, item in pairs(scrollFrame:GetChildren()) do
		if item:IsA("TextButton") then
			item:Destroy()
		end
	end
	
	local itemCount = #list
	local itemHeight = 28
	
	for i, value in ipairs(list) do
		local item = utility:Create("TextButton", {
			Parent = scrollFrame,
			BackgroundColor3 = Color3.fromRGB(55, 55, 75),
			BackgroundTransparency = 0.3,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, itemHeight),
			Font = Enum.Font.Gotham,
			Text = value,
			TextColor3 = Color3.fromRGB(200, 200, 210),
			TextSize = 10,
			AutoButtonColor = false
		})
		
		item.MouseButton1Click:Connect(function()
			dropdown.Button.Text = value
			
			if callback then
				callback(value)
			end
			
			utility:Tween(listFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
			utility:Tween(dropdown, {Size = UDim2.new(1, 0, 0, 32)}, 0.15)
			wait(0.15)
			listFrame.Visible = false
		end)
	end
	
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, itemCount * itemHeight)
	listFrame.Visible = true
	
	local displayHeight = math.min(itemCount * itemHeight, 120)
	utility:Tween(listFrame, {Size = UDim2.new(1, 0, 0, displayHeight)}, 0.15)
	utility:Tween(dropdown, {Size = UDim2.new(1, 0, 0, 32 + displayHeight)}, 0.15)
end

function section:updateButton(button, title)
	if button and button:FindFirstChild("Title") then
		button.Text = title
	end
end

function section:updateToggle(toggle, title, value)
	if not toggle then return end
	
	if title then
		toggle.Title.Text = title
	end
	
	if value ~= nil then
		local dot = toggle.ToggleButton.Dot
		if value then
			utility:Tween(dot, {Position = UDim2.new(0, 22, 0.5, -8)}, 0.15)
		else
			utility:Tween(dot, {Position = UDim2.new(0, 2, 0.5, -8)}, 0.15)
		end
	end
end

function section:updateTextbox(textbox, title, value)
	if not textbox then return end
	
	if title then
		textbox.Title.Text = title
	end
	
	if value then
		textbox.Input.Text = value
	end
end

function section:updateSlider(slider, title, value, min, max)
	if not slider then return end
	
	if title then
		slider.Title.Text = title
	end
	
	if value then
		local percent = (value - (min or 0)) / ((max or 100) - (min or 0))
		slider.Value.Text = tostring(value)
		slider.SliderBar.Fill.Size = UDim2.new(percent, 0, 1, 0)
	end
end

function section:updateKeybind(keybind, title, key)
	if not keybind then return end
	
	if title then
		keybind.Title.Text = title
	end
	
	if key then
		keybind.Button.Text.Text = key.Name
	end
end

function library:SelectPage(page, toggle)
	if toggle and self.focusedPage == page then
		return
	end
	
	local button = page.button
	
	if toggle then
		button.BackgroundColor3 = Color3.fromRGB(65, 65, 85)
		button.BackgroundTransparency = 0.2
		button.Title.TextTransparency = 0
		button.Title.Font = Enum.Font.GothamSemibold
		
		if self.focusedPage then
			self:SelectPage(self.focusedPage)
		end
		
		self.focusedPage = page
		
		if page.contentContainer then
			page.contentContainer.Visible = true
		end
	else
		button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
		button.BackgroundTransparency = 0.2
		button.Title.TextTransparency = 0.4
		button.Title.Font = Enum.Font.Gotham
		
		if page.contentContainer then
			page.contentContainer.Visible = false
		end
	end
	
	self:ResizeContent()
end

function library:ResizeContent()
	local totalHeight = 0
	
	if self.focusedPage and self.focusedPage.contentContainer then
		for _, section in pairs(self.focusedPage.contentContainer:GetChildren()) do
			if section:IsA("Frame") then
				local sectionHeight = 0
				local titleLabel = section:FindFirstChild("Container") and section.Container:FindFirstChild("Title")
				
				if titleLabel then
					sectionHeight = titleLabel.AbsoluteSize.Y + 16
				end
				
				local listLayout = section:FindFirstChild("Container") and section.Container:FindFirstChildOfClass("UIListLayout")
				if listLayout then
					for _, item in pairs(section.Container:GetChildren()) do
						if item:IsA("TextButton") or item:IsA("Frame") then
							sectionHeight = sectionHeight + item.AbsoluteSize.Y + 4
						end
					end
				end
				
				section.Size = UDim2.new(1, 0, 0, math.max(sectionHeight, 28))
				totalHeight = totalHeight + section.AbsoluteSize.Y + 8
			end
		end
	end
	
	if self.contentFrame then
		self.contentFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
	end
end

print("Luna UI Library Loaded!")
return library
